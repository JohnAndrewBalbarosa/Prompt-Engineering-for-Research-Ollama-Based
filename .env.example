# Local-only runtime settings
EXPERIMENT_CONFIG_PATH=config/experiment.json
OLLAMA_BASE_URL=http://localhost:11434

# Optional local request tuning
OLLAMA_REQUEST_INTERVAL_SECONDS=0.0
OLLAMA_JUDGE_REQUEST_INTERVAL_SECONDS=0.0
OLLAMA_RETRY_BACKOFF_SECONDS=2.0
OLLAMA_MAX_RETRY_BACKOFF_SECONDS=10.0
OLLAMA_JUDGE_RETRY_BACKOFF_SECONDS=2.0
OLLAMA_JUDGE_MAX_RETRY_BACKOFF_SECONDS=10.0

# Optional rate-limit buckets
OLLAMA_GENERATION_BUCKET=ollama-generation
OLLAMA_JUDGE_BUCKET=ollama-judge
